# Environment Configuration Example for CivicPulse Backend

# Application Settings
ENVIRONMENT=production
DEBUG=false
PORT=8000
APP_BASE_URL=https://civicpulse-api.onrender.com
FRONTEND_ORIGIN=https://civicpulse.vercel.app,http://localhost:5173
CORS_ORIGINS=https://civicpulse.vercel.app,http://localhost:5173

# Database Configuration
# Local SQLite Default:
DATABASE_URL=sqlite:///civicpulse.db
# Render PostgreSQL Example:
# DATABASE_URL=postgresql://civicpulse_user:password@dpg-xxxx-a.render.com/civicpulse_db

# Redis Cache & Rate Limiting Configuration (Render Redis or Redislabs)
REDIS_URL=redis://red-xxxx:6379/0
RATE_LIMIT_PER_MINUTE=120

# Auth & Security Configuration
SECRET_KEY=civicpulse_super_secret_jwt_key_2026_change_in_production!
JWT_SECRET=civicpulse_super_secret_jwt_key_2026_change_in_production!
JWT_SECRET_KEY=civicpulse_super_secret_jwt_key_2026_change_in_production!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini Vision AI API Key
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Email Gateway (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@civicpulse.org

# WhatsApp Integration (Twilio)
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
