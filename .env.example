# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key

# SendGrid Email Configuration
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=your-verified-sender@example.com

# Production Live URL (used in WhatsApp success reply links)
APP_BASE_URL=https://civicpulse-xxxx-xx.a.run.app

# Optional log configuration (info, debug, warning, error)
LOG_LEVEL=info

# ─── WhatsApp Reporting Channel (Twilio Sandbox) ───────────────────────────
# Set WHATSAPP_ENABLED=true and fill in Twilio credentials to activate.
# Sandbox: Twilio Console → Messaging → Try it Out → WhatsApp
# Production: replace the adapter helpers in whatsapp.py with Meta Cloud API.
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
